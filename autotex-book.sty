\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{autotex-book}[2026/02/09 AutoTex Book Style]

% =====================================================================
% KDP / Print-on-Demand Options
% =====================================================================
%
% KDP compliance is the default. All books are produced at print-ready
% trim sizes with proper margins and gutter for binding.
%
% Usage:
%   \usepackage{autotex-book}                    % default: novel (6x9)
%   \usepackage[kdp=pocket]{autotex-book}        % KDP 5.25x8
%   \usepackage[kdp=letter]{autotex-book}        % KDP 8.5x11
%   \usepackage[bleed]{autotex-book}             % with bleed marks
%   \usepackage[gutter=0.5in]{autotex-book}      % custom gutter
%
% Supported KDP trim sizes:
%   pocket      = 5.25 x 8 in
%   digest      = 5.5 x 8.5 in
%   novel       = 6 x 9 in      (default)
%   royal       = 6.14 x 9.21 in
%   crown       = 7 x 10 in
%   large       = 7.5 x 9.25 in
%   letter      = 8.5 x 11 in
%   ustrade     = 6 x 9 in      (alias for novel)
%   uktrade     = 5.06 x 7.81 in
%
% Layout: oneside geometry with gutter added to the left (binding) margin.
% =====================================================================

\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

\SetupKeyvalOptions{
  family=atxbook,
  prefix=atxbook@
}

% --- KDP trim size (default: novel) ---
\DeclareStringOption[novel]{kdp}

% --- Bleed toggle ---
\DeclareBoolOption[false]{bleed}

% --- Gutter override (default empty = auto 0.375in) ---
\DeclareStringOption[]{gutter}

% --- Paper color (for informational purposes / future ICC profile) ---
\DeclareStringOption[white]{paper}

% Process options
\ProcessKeyvalOptions*

% --- Internal dimensions ---
\newlength{\atxbook@trimw}
\newlength{\atxbook@trimh}
\newlength{\atxbook@gutterdim}
\newlength{\atxbook@mtop}
\newlength{\atxbook@mbottom}
\newlength{\atxbook@mouter}
\newlength{\atxbook@minner}
\newlength{\atxbook@bleedoffset}

% =====================================================================
% Resolve KDP trim size
% =====================================================================

% Handle bare option / empty → default to "novel"
\ifdefstring{\atxbook@kdp}{true}{\def\atxbook@kdp{novel}}{}%
\ifdefstring{\atxbook@kdp}{}{\def\atxbook@kdp{novel}}{}%

% --- Set trim dimensions based on size name ---
\ifdefstring{\atxbook@kdp}{pocket}{%
  \setlength{\atxbook@trimw}{5.25in}%
  \setlength{\atxbook@trimh}{8in}%
}{}%
\ifdefstring{\atxbook@kdp}{uktrade}{%
  \setlength{\atxbook@trimw}{5.06in}%
  \setlength{\atxbook@trimh}{7.81in}%
}{}%
\ifdefstring{\atxbook@kdp}{digest}{%
  \setlength{\atxbook@trimw}{5.5in}%
  \setlength{\atxbook@trimh}{8.5in}%
}{}%
\ifdefstring{\atxbook@kdp}{novel}{%
  \setlength{\atxbook@trimw}{6in}%
  \setlength{\atxbook@trimh}{9in}%
}{}%
\ifdefstring{\atxbook@kdp}{ustrade}{%
  \setlength{\atxbook@trimw}{6in}%
  \setlength{\atxbook@trimh}{9in}%
}{}%
\ifdefstring{\atxbook@kdp}{royal}{%
  \setlength{\atxbook@trimw}{6.14in}%
  \setlength{\atxbook@trimh}{9.21in}%
}{}%
\ifdefstring{\atxbook@kdp}{crown}{%
  \setlength{\atxbook@trimw}{7in}%
  \setlength{\atxbook@trimh}{10in}%
}{}%
\ifdefstring{\atxbook@kdp}{large}{%
  \setlength{\atxbook@trimw}{7.5in}%
  \setlength{\atxbook@trimh}{9.25in}%
}{}%
\ifdefstring{\atxbook@kdp}{letter}{%
  \setlength{\atxbook@trimw}{8.5in}%
  \setlength{\atxbook@trimh}{11in}%
}{}%

% --- Margins (comfortable defaults above KDP minimums) ---
\setlength{\atxbook@mtop}{0.75in}%
\setlength{\atxbook@mbottom}{0.75in}%
\setlength{\atxbook@mouter}{0.625in}%

% --- Gutter: use override or default 0.375in ---
\ifdefempty{\atxbook@gutter}{%
  \setlength{\atxbook@gutterdim}{0.375in}%
}{%
  \setlength{\atxbook@gutterdim}{\atxbook@gutter}%
}%

% Left margin = outer margin + gutter (binding side)
\setlength{\atxbook@minner}{\atxbook@mouter}%
\addtolength{\atxbook@minner}{\atxbook@gutterdim}%

% --- Bleed ---
\ifatxbook@bleed
  \setlength{\atxbook@bleedoffset}{0.125in}%
  \addtolength{\atxbook@mtop}{\atxbook@bleedoffset}%
  \addtolength{\atxbook@mbottom}{\atxbook@bleedoffset}%
  \addtolength{\atxbook@mouter}{\atxbook@bleedoffset}%
  \addtolength{\atxbook@trimw}{\atxbook@bleedoffset}%
  \addtolength{\atxbook@trimh}{0.25in}%
\fi

% =====================================================================
% Geometry — oneside, left margin includes gutter for binding
% =====================================================================
\RequirePackage[
  paperwidth=\atxbook@trimw,
  paperheight=\atxbook@trimh,
  top=\atxbook@mtop,
  bottom=\atxbook@mbottom,
  right=\atxbook@mouter,
  left=\atxbook@minner
]{geometry}

% =====================================================================
% Encoding and fonts
% =====================================================================
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% =====================================================================
% Headers / footers — UNIFORM on all pages (no odd/even distinction)
% =====================================================================
\RequirePackage{fancyhdr}

% =====================================================================
% Math
% =====================================================================
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{mathtools}

% =====================================================================
% Tables
% =====================================================================
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{multirow}

% =====================================================================
% Figures and graphics
% =====================================================================
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{subcaption}
\RequirePackage[
  font=small,
  labelfont=bf,
  labelsep=period,
  justification=centering
]{caption}

% =====================================================================
% Colored boxes
% =====================================================================
\RequirePackage[most]{tcolorbox}
\RequirePackage{xcolor}

% =====================================================================
% Code listings
% =====================================================================
\RequirePackage{listings}

% =====================================================================
% Graphs and diagrams
% =====================================================================
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}

% =====================================================================
% Bibliography
% =====================================================================
\RequirePackage[numbers,sort&compress]{natbib}

% =====================================================================
% Hyperlinks and cross-references
% =====================================================================
\RequirePackage[
  colorlinks=true,
  linkcolor=blue!60!black,
  citecolor=green!40!black,
  urlcolor=blue!70!black,
  bookmarks=true,
  bookmarksnumbered=true
]{hyperref}
\RequirePackage{cleveref}

% =====================================================================
% Miscellaneous
% =====================================================================
\RequirePackage{enumitem}
\RequirePackage{microtype}

% =====================================================================
% Typography refinements
% =====================================================================
\setlength{\parindent}{1.5em}
\setlength{\parskip}{0pt plus 1pt}

% =====================================================================
% Custom tcolorbox environments — professional, elegant styling
% =====================================================================

% Definition box — blue accent
\newtcolorbox{definitionbox}[1][]{%
  colback=blue!3!white,
  colframe=blue!55!black,
  fonttitle=\bfseries,
  title={#1},
  rounded corners,
  boxrule=0.7pt,
  arc=3pt,
  left=8pt, right=8pt,
  top=6pt, bottom=6pt
}

% Theorem box — green accent
\newtcolorbox{theorembox}[1][]{%
  colback=green!3!white,
  colframe=green!40!black,
  fonttitle=\bfseries,
  title={#1},
  rounded corners,
  boxrule=0.7pt,
  arc=3pt,
  left=8pt, right=8pt,
  top=6pt, bottom=6pt
}

% Example box — amber accent
\newtcolorbox{examplebox}[1][]{%
  colback=orange!3!white,
  colframe=orange!60!black,
  fonttitle=\bfseries,
  title={#1},
  rounded corners,
  boxrule=0.7pt,
  arc=3pt,
  left=8pt, right=8pt,
  top=6pt, bottom=6pt
}

% Warning/Note box — red accent
\newtcolorbox{notebox}[1][]{%
  colback=red!3!white,
  colframe=red!55!black,
  fonttitle=\bfseries,
  title={#1},
  rounded corners,
  boxrule=0.7pt,
  arc=3pt,
  left=8pt, right=8pt,
  top=6pt, bottom=6pt
}

% =====================================================================
% Code listing style
% =====================================================================
\lstset{
  basicstyle=\ttfamily\small,
  keywordstyle=\bfseries\color{blue!60!black},
  commentstyle=\itshape\color{green!40!black},
  stringstyle=\color{orange!70!black},
  numbers=left,
  numberstyle=\tiny\color{gray},
  numbersep=8pt,
  frame=single,
  framerule=0.4pt,
  rulecolor=\color{gray!50},
  breaklines=true,
  breakatwhitespace=true,
  tabsize=4,
  showstringspaces=false,
  aboveskip=10pt,
  belowskip=10pt
}

% =====================================================================
% Header/footer setup — uniform on every page
% =====================================================================
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\nouppercase{\leftmark}}
\fancyhead[R]{\nouppercase{\rightmark}}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

% Plain style (used on chapter-opening pages)
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[C]{\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

% =====================================================================
% Graphics path
% =====================================================================
\graphicspath{{assets/}}

% =====================================================================
% KDP info (log output)
% =====================================================================
\PackageInfo{autotex-book}{%
  KDP mode: size=\atxbook@kdp,
  trim=\the\atxbook@trimw\space x \the\atxbook@trimh,
  gutter=\the\atxbook@gutterdim,
  bleed=\ifatxbook@bleed yes\else no\fi,
  paper=\atxbook@paper
}
